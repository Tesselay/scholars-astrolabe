{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@utils/*": ["utils/*"],
      "@ui/*": ["ui/components/*", "ui/compositions/*", "ui/layouts/*"],
      "@content/*": ["content/*"],
      "@styles/*": ["styles/*"],
      "@types/*": ["types/*"]
    },
    "types": ["astro/client", "vite/client", "vitest"]
  },
  "exclude": ["astro.config.ts", "node_modules"]
}
