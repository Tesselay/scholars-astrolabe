---
import { getRelativeLocaleUrl } from "astro:i18n";

import Layout from "&ui/Layout.astro";

import { defaultLocale } from "&utils/core/i18n/locale/definition.ts";

const pageTitle = "Redirecting…";

const target = getRelativeLocaleUrl(defaultLocale, "/");
---

<Layout pageTitle={pageTitle}>
  <Fragment slot="head">
    <meta content={`0; url=${target}`} http-equiv="refresh" />
    <meta content="noindex" name="robots" />
  </Fragment>

  <p>Redirecting to <a href={target}>{target}</a></p>
</Layout>
