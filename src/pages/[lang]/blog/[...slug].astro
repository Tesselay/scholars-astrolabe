---
import { getCollection, render } from "astro:content";

import BlogPostLayout from "&ui/BlogPostLayout.astro";

import { neutralizeUrlPath } from "&utils/compositional/routing/url.ts";
import { getLocaleRouteFromPathStrict } from "&utils/core/i18n/locale/path.ts";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .map((post) => {
      const locale = getLocaleRouteFromPathStrict(post.id);
      const slug = neutralizeUrlPath(post.id);

      return {
        params: { lang: locale, slug },
        props: post,
      };
    });
}

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout frontmatter={post.data}>
  <Content />
</BlogPostLayout>
