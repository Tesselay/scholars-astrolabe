---
import Layout from "../../../layouts/Layout.astro";
import { metaLoader } from "@/utils/compositional/i18n/metaLoader.ts";
import { pathsForAllLocales } from "@/utils/compositional/content/filter.ts";

export function getStaticPaths() {
  return pathsForAllLocales();
}

const lang = Astro.currentLocale;
const meta = await metaLoader.getAsync(lang);
const title = meta.folio.title;
const description = meta.folio.description;
---

<Layout pageTitle={title} description={description}>
  <h1>{title}</h1>
</Layout>
