  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "sync": "astro sync",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --fix",
    "prepare": "husky",
    "pretest": "astro sync --mode test",
    "test": "vitest run",
    "test:debug": "vitest run --reporter=verbose",
    "test:cov": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:ui": "playwright test --ui",
    "test:a11y": "pa11y-ci",
    "e2e": "playwright test",
    "clean": "rm -rf .astro dist node_modules"
  },
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/rss": "4.0.17",
